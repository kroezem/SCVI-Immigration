---
import Container from "@/components/container.astro";

// TODO: Service chip labels are pending client sign-off.
const serviceGroups = [
  {
    label: "Permanent Residency & Citizenship",
    services: [
      "BC Nominee Program",
      "Permanent Residency – Express Entry",
      "Canadian Citizenship",
    ],
  },
  {
    label: "Work & Study",
    services: [
      "Work Permits",
      "Post-Graduate Work Permit",
      "Study Permits",
    ],
  },
  {
    label: "Family & Visitors",
    services: [
      "Spousal and Common-Law Sponsorship",
      "Parental Sponsorship",
      "Visitor Visa",
    ],
  },
];
---

<section class="section-padding">
  <Container>
    <h2 class="text-4xl font-bold text-navy-900 lg:text-5xl lg:tracking-tight">
      Services
    </h2>

    <div class="mt-7 grid gap-4 lg:grid-cols-3">
      {
        serviceGroups.map((group) => (
          <div
            class="rounded-[18px] bg-white p-[22px] shadow-[0_4px_16px_rgba(15,36,64,0.06)]">
            <span class="inline-block rounded-full bg-teal-chip px-3 py-1.5 text-[10px] font-bold tracking-[0.08em] text-teal-600 uppercase">
              {group.label}
            </span>
            <ul class="mt-4 space-y-1.5 text-base leading-[1.6] font-semibold text-navy-900 sm:text-lg">
              {group.services.map((service) => <li>{service}</li>)}
            </ul>
          </div>
        ))
      }
    </div>
  </Container>
</section>
