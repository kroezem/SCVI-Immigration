---
import Link from "@/components/ui/link.astro";
import { Icon } from "astro-icon/components";
---

<main
  class="grid lg:grid-cols-2 place-items-center pt-8 pb-8 md:pt-12 md:pb-24 gap-10">
  <div>
    <span class="text-teal-600 font-semibold uppercase tracking-wide text-sm">
      Trusted Canadian Immigration Consultants
    </span>
    <h1
      class="text-4xl lg:text-6xl xl:text-7xl font-bold lg:tracking-tight xl:tracking-tighter text-navy-900 mt-3">
      Your Path to Canada Starts Here
    </h1>
    <p class="text-lg mt-4 text-navy-600 max-w-xl">
      SCVI Immigration Law provides personalized immigration services for individuals, families, students, and workers. We combine professional expertise with a client-first approach to help you navigate Canada's immigration system with confidence.
    </p>
    <div class="mt-6 flex flex-col sm:flex-row gap-3">
      <Link
        href="/contact"
        class="flex gap-1 items-center justify-center">
        <Icon class="text-white w-5 h-5" name="bx:bx-calendar" />
        Book a Consultation
      </Link>
      <Link
        size="lg"
        style="outline"
        href="/contact"
        class="flex gap-1 items-center justify-center">
        <Icon class="text-navy-700 w-4 h-4" name="bx:bx-envelope" />
        Contact Us
      </Link>
    </div>
  </div>
  <div class="w-full order-first lg:order-none">
    <!-- Video: The Six / Pexels -->
    <video
      class="w-full aspect-[4/3] rounded-xl object-cover shadow-lg"
      autoplay
      muted
      loop
      playsinline
      poster="/video/victoria-hero.jpg">
      <source src="/video/victoria-hero.mp4" type="video/mp4" />
    </video>
  </div>
</main>
