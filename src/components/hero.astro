---
import Container from "@/components/container.astro";
import Link from "@/components/ui/link.astro";
import { Icon } from "astro-icon/components";
---

<section class="section-padding">
  <Container>
    <div class="grid gap-10 lg:grid-cols-2 lg:place-items-center">
      <div>
        <span class="section-eyebrow">
          Immigration Law · British Columbia
        </span>
        <h1
          class="mt-3 text-4xl font-bold text-navy-900 lg:text-6xl lg:tracking-tight xl:text-7xl xl:tracking-tighter">
          Your Path to Canada Starts Here
        </h1>
        <p class="mt-5 max-w-xl text-lg text-navy-600">
          SCVI Immigration Law provides personalized immigration services for individuals, families, students, and workers. We combine professional expertise with a client-first approach to help you navigate Canada's immigration system with confidence.
        </p>
        <div class="mt-6 flex flex-col gap-3 sm:flex-row">
          <Link
            href="/contact"
            class="flex items-center justify-center gap-1">
            <Icon class="h-5 w-5 text-white" name="bx:bx-calendar" />
            Book a Consultation
          </Link>
          <Link
            size="lg"
            style="outline"
            href="/contact"
            class="flex items-center justify-center gap-1">
            <Icon class="h-4 w-4 text-navy-700" name="bx:bx-envelope" />
            Contact Us
          </Link>
        </div>
      </div>
      <div class="order-first w-full lg:order-none">
        <!-- Video: The Six / Pexels -->
        <video
          class="aspect-[4/3] w-full rounded-xl object-cover shadow-lg"
          autoplay
          muted
          loop
          playsinline
          poster="/video/victoria-hero.jpg">
          <source src="/video/victoria-hero.mp4" type="video/mp4" />
        </video>
      </div>
    </div>
  </Container>
</section>
