---
import Container from "@/components/container.astro";
import Link from "@/components/ui/link.astro";
import { Icon } from "astro-icon/components";
---

<section class="section-padding">
  <Container>
    <div class="grid gap-8 lg:grid-cols-[1.05fr_0.95fr] lg:place-items-center lg:gap-12">
      <div>
        <span class="inline-block rounded-full bg-brand-50 px-[15px] py-[7px] text-sm font-semibold text-brand-700">
          Immigration Law · British Columbia
        </span>
        <h1
          class="mt-4 text-4xl font-bold tracking-[-0.025em] text-navy-900 sm:text-5xl lg:text-6xl xl:text-7xl">
          Your Path to Canada Starts <span class="text-brand-700">Here</span>
        </h1>
        <p class="mt-5 max-w-xl text-lg leading-8 text-body">
          SCVI Immigration Law provides personalized immigration services for individuals, families, students, and workers. We combine professional expertise with a client-first approach to help you navigate Canada's immigration system with confidence.
        </p>
        <div class="mt-6 flex flex-col gap-3 sm:flex-row">
          <Link
            href="/contact"
            class="flex items-center justify-center gap-1">
            <Icon class="h-5 w-5 text-white" name="bx:bx-calendar" />
            Book a Consultation
          </Link>
          <Link
            size="lg"
            style="outline"
            href="/contact"
            class="flex items-center justify-center gap-1">
            <Icon class="h-4 w-4 text-navy-700" name="bx:bx-envelope" />
            Contact Us
          </Link>
        </div>
      </div>
      <div class="order-first w-full lg:order-none">
        <!-- Video: The Six / Pexels -->
        <video
          class="aspect-square w-full rounded-[28px] object-cover shadow-[0_18px_44px_rgba(15,36,64,0.18)]"
          autoplay
          muted
          loop
          playsinline
          poster="/video/victoria-hero.jpg">
          <source src="/video/victoria-hero.mp4" type="video/mp4" />
        </video>
      </div>
    </div>
  </Container>
</section>
