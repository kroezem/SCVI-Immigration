---
import Container from "@/components/container.astro";
import Link from "@/components/ui/link.astro";
import { Astronav, MenuItems, MenuIcon } from "astro-navbar";

const menuitems = [
  {
    title: "About",
    path: "/about",
  },
  {
    title: "Contact",
    path: "/contact",
  },
];
---

<Container>
  <header
    id="scvi-mobile-nav"
    class="scvi-mobile-nav my-5 flex flex-col items-center rounded-full bg-white p-2 pl-4 shadow-[0_4px_18px_rgba(15,36,64,0.07)] lg:flex-row lg:justify-between">
    <Astronav>
      <div
        class="scvi-mobile-nav-header flex w-full lg:w-auto items-center justify-between">
        <a href="/" class="flex items-center gap-2 text-base sm:text-lg"
          ><img
            src="/scvi-icon.png"
            alt="SCVI Immigration Law logo"
            class="h-12 w-12 object-contain"
          /><span class="font-bold text-navy-900">SCVI</span><span
            class="text-body">Immigration Law</span
          >
        </a>
        <div class="flex h-11 w-11 items-center justify-center rounded-full bg-teal-500 lg:hidden">
          <MenuIcon class="h-5 w-5 text-white" />
        </div>
      </div>
      <MenuItems
        class="hidden w-full flex-1 pt-8 lg:ml-auto lg:flex lg:w-auto lg:flex-none lg:pt-0">
        <div
          class="flex min-h-[calc(100dvh-7.25rem)] flex-col items-center justify-center lg:min-h-0 lg:flex-row lg:justify-start">
          <ul
            class="flex flex-col items-center gap-6 lg:flex-row lg:items-stretch lg:gap-3">
            {
              menuitems.map((item) => (
                <>
                  <li>
                    <a
                      href={item.path}
                      class="flex items-center py-2 text-3xl font-bold text-navy-900 transition hover:text-teal-600 lg:px-3 lg:text-base lg:font-medium lg:text-body lg:hover:text-navy-900">
                      <span> {item.title}</span>
                    </a>
                  </li>
                </>
              ))
            }
          </ul>
          <div class="mt-9 flex w-full max-w-xs items-center gap-4 lg:hidden">
            <Link href="/contact" size="md" block>Book a Consultation</Link>
          </div>
          <div
            class="mt-7 w-full max-w-xs border-t border-navy-100 pt-6 text-center lg:hidden">
            <p class="text-xs font-semibold tracking-wide text-teal-600 uppercase">
              Quick Contact
            </p>
            <div class="mt-3 flex flex-col gap-2 text-sm text-body">
              <a href="tel:+17784300387" class="hover:text-teal-600">
                778-430-0387
              </a>
              <a
                href="mailto:info@scviimmigrationlaw.ca"
                class="hover:text-teal-600">
                info@scviimmigrationlaw.ca
              </a>
            </div>
          </div>
        </div>
      </MenuItems>
    </Astronav>
    <div>
      <div class="hidden lg:flex items-center gap-4">
        <Link href="/contact" size="md">Book a Consultation</Link>
      </div>
    </div>
  </header>
</Container>

<script>
  const navOpenClass = "scvi-mobile-nav-open";
  const navShellOpenClass = "is-open";
  const mobileQuery = "(max-width: 1023px)";

  function initMobileNavOverlay() {
    const nav = document.getElementById("scvi-mobile-nav");
    const menuItems = nav?.querySelector(".astronav-items");

    if (!nav || !menuItems) {
      return;
    }

    const syncOverlayState = () => {
      const isMobile = window.matchMedia(mobileQuery).matches;
      const isOpen = isMobile && !menuItems.classList.contains("hidden");

      document.body.classList.toggle(navOpenClass, isOpen);
      nav.classList.toggle(navShellOpenClass, isOpen);
    };

    const observer = new MutationObserver(syncOverlayState);
    observer.observe(menuItems, { attributes: true, attributeFilter: ["class"] });

    const mediaQuery = window.matchMedia(mobileQuery);
    mediaQuery.addEventListener("change", syncOverlayState);

    document.addEventListener(
      "astro:before-swap",
      () => {
        document.body.classList.remove(navOpenClass);
        nav.classList.remove(navShellOpenClass);
        observer.disconnect();
        mediaQuery.removeEventListener("change", syncOverlayState);
      },
      { once: true }
    );

    syncOverlayState();
  }

  ["DOMContentLoaded", "astro:after-swap"].forEach((event) => {
    document.addEventListener(event, initMobileNavOverlay);
  });
</script>

<style is:global>
  body.scvi-mobile-nav-open {
    overflow: hidden;
  }
</style>

<style>
  @media (max-width: 63.999rem) {
    .scvi-mobile-nav.is-open {
      position: fixed;
      inset: 0;
      z-index: 100;
      align-items: stretch;
      margin: 0;
      padding: 1.25rem;
      border-radius: 0;
      background: var(--color-page);
      box-shadow: none;
    }

    .scvi-mobile-nav.is-open .scvi-mobile-nav-header {
      border-radius: 9999px;
      background: white;
      padding: 0.5rem 0.5rem 0.5rem 1rem;
      box-shadow: 0 4px 18px rgba(15, 36, 64, 0.07);
    }
  }
</style>
