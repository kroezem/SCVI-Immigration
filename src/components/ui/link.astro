---
interface Props {
  href: string;
  size?: "md" | "lg";
  block?: boolean;
  style?: "outline" | "primary" | "inverted" | "muted";
  class?: string;
  [x: string]: any;
}

const {
  href,
  block,
  size = "lg",
  style = "primary",
  class: className,
  ...rest
} = Astro.props;

const sizes = {
  lg: "px-5 py-2.5",
  md: "px-4 py-2",
};

const styles = {
  outline: "bg-white border border-cool-border hover:border-teal-500 text-navy-700",
  primary: "bg-teal-500 text-white hover:bg-teal-600 border border-transparent",
  inverted: "bg-white text-teal-600 hover:bg-cream-50 border border-transparent",
  muted: "bg-cream-100 hover:bg-navy-50 border-2 border-transparent text-navy-800",
};
---

<a
  href={href}
  {...rest}
  class:list={[
    "rounded-full text-center font-semibold transition focus-visible:outline-none focus-visible:ring-2 focus-visible:ring-teal-500 focus-visible:ring-offset-2",
    block && "w-full",
    sizes[size],
    styles[style],
    className,
  ]}
  ><slot />
</a>
