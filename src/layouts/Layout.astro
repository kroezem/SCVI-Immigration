---
import { SEO } from "astro-seo";
import Analytics from "@vercel/analytics/astro";
import Footer from "@/components/footer.astro";
import Navbar from "@/components/navbar/navbar.astro";
import "@fontsource-variable/inter/index.css";
import "@fontsource-variable/bricolage-grotesque";
import "../styles/global.css";

export interface Props {
  title?: string;
  fullTitle?: string;
  description?: string;
}

const canonicalURL = new URL(Astro.url.pathname, Astro.site).toString();
const ogImageURL = new URL("/video/victoria-hero.jpg", Astro.site).toString();

const { title, fullTitle, description: pageDescription } = Astro.props;

const makeTitle = fullTitle ?? (title ? `${title} | SCVI Immigration Law` : "SCVI Immigration Law");
const defaultDescription = "SCVI Immigration Law provides personalized immigration services for individuals, families, students, and workers. We combine professional expertise with a client-first approach to help you navigate Canada's immigration system with confidence.";
const description = pageDescription ?? defaultDescription;

const legalService = {
  "@context": "https://schema.org",
  "@type": "LegalService",
  name: "SCVI Immigration Law",
  address: {
    "@type": "PostalAddress",
    streetAddress: "2887 Peatt Road",
    addressLocality: "Langford",
    addressRegion: "BC",
    postalCode: "V9B 3V7",
    addressCountry: "CA",
  },
  telephone: "778-430-0387",
  email: "info@scviimmigrationlaw.ca",
  url: Astro.site?.origin,
  openingHoursSpecification: {
    "@type": "OpeningHoursSpecification",
    dayOfWeek: ["Monday", "Tuesday", "Wednesday", "Thursday"],
    opens: "09:00",
    closes: "16:00",
  },
};
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <link rel="preload" as="image" href="/scvi-icon.png" />
    <meta name="generator" content={Astro.generator} />

    <!-- <link rel="preload" as="image" href={src} alt="Hero" /> -->
    <SEO
      title={makeTitle}
      description={description}
      canonical={canonicalURL}
      twitter={{
        card: "summary_large_image",
        image: ogImageURL,
      }}
      extend={{
        meta: [
          { property: "og:title", content: makeTitle },
          { property: "og:description", content: description },
          { property: "og:type", content: "website" },
          { property: "og:url", content: canonicalURL },
          { property: "og:image", content: ogImageURL },
        ],
      }}
    />
    <script type="application/ld+json" set:html={JSON.stringify(legalService)} />
  </head>
  <body>
    <Navbar />
    <slot />
    <Footer />
    <style is:global>
      /* Improve Page speed */
      /* https://css-tricks.com/almanac/properties/c/content-visibility/ */
      img {
        content-visibility: auto;
      }
    </style>
    <Analytics />
  </body>
</html>
