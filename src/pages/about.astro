---
import Layout from "@/layouts/Layout.astro";
import Container from "@/components/container.astro";
---

<Layout
  fullTitle="About Sonia Chauhan | Immigration Lawyer in Victoria, BC"
  description="Sonia is the founder of SCVI Immigration Law Office and a dedicated immigration lawyer with over five years of experience practicing immigration law.">
  <main>
    <section class="section-padding">
      <Container>
        <div class="grid gap-10 lg:grid-cols-[minmax(0,0.95fr)_minmax(0,1.05fr)] lg:items-center">
          <div class="max-w-2xl">
            <h1 class="text-4xl font-bold tracking-tight text-navy-900 lg:text-5xl">
              Meet Sonia Chauhan (B.A, LL.B)
            </h1>
            <div class="section-copy">
              <p>
                Sonia is the founder of SCVI Immigration Law Office and a dedicated immigration lawyer with over five years of experience practicing immigration law in British Columbia. Sonia graduated from law school in the United Kingdom. Having lived abroad herself, she understands firsthand what it means to be a newcomer to Canada. She is passionate about helping individuals, families, and students navigate Canada's immigration system with confidence.
              </p>
              <p>
                Known for her client-centred approach, Sonia provides practical legal guidance, clear communication, and personalized solutions tailored to each client's personal circumstances. She is committed to making the immigration process as straightforward and stress-free as possible while helping clients achieve their goals in Canada.
              </p>
            </div>
          </div>
          <div class="w-full">
            <!-- Video: Oleg Tischenkov / Pexels -->
            <video
              class="aspect-[4/3] w-full rounded-[28px] object-cover shadow-[0_18px_44px_rgba(15,36,64,0.14)]"
              aria-label="Canadian flag waving against a blue sky"
              data-about-flag-video
              autoplay
              muted
              loop
              playsinline
              poster="/video/about-flag.jpg">
              <source src="/video/about-flag.mp4" type="video/mp4" />
            </video>
          </div>
        </div>
      </Container>
    </section>
    <script>
      const ABOUT_VIDEO_PLAYBACK_RATE = 0.6;
      const aboutVideo = document.querySelector<HTMLVideoElement>(
        "[data-about-flag-video]",
      );

      if (aboutVideo) {
        const setPlaybackRate = () => {
          aboutVideo.playbackRate = ABOUT_VIDEO_PLAYBACK_RATE;
        };

        if (aboutVideo.readyState >= HTMLMediaElement.HAVE_METADATA) {
          setPlaybackRate();
        } else {
          aboutVideo.addEventListener("loadedmetadata", setPlaybackRate, {
            once: true,
          });
        }
      }
    </script>
  </main>
</Layout>
