---
import Contactform from "@/components/contactform.astro";
import Container from "@/components/container.astro";
import Sectionhead from "@/components/sectionhead.astro";
import Layout from "@/layouts/Layout.astro";
import { Icon } from "astro-icon/components";

const mapsHref = "https://www.google.com/maps/search/?api=1&query=2887%20Peatt%20Road%2C%20Langford%2C%20BC%20V9B%203V7";
---

<Layout
  fullTitle="Contact SCVI Immigration Law | Langford, BC"
  description="Contact SCVI Immigration Law in Langford, BC. Office at 2887 Peatt Road — book a consultation or reach us by phone or email.">
  <main>
    <section class="section-padding">
      <Container>
        <Sectionhead>
          <Fragment slot="title">Contact Us</Fragment>
        </Sectionhead>

        <div class="mx-auto mt-10 grid max-w-5xl gap-5 lg:grid-cols-[0.9fr_1.1fr]">
          <div class="space-y-9 rounded-[18px] bg-white p-6 shadow-[0_4px_16px_rgba(15,36,64,0.06)] sm:p-8">
            <div>
              <h2 class="inline-flex rounded-full bg-brand-50 px-3 py-1.5 text-xs font-bold tracking-[0.08em] text-brand-700 uppercase">Our Office</h2>
              <div class="mt-5 space-y-3 text-lg text-body">
                <div class="flex items-start gap-3">
                  <Icon class="mt-1 h-5 w-5 shrink-0 text-brand-700" name="uil:map-marker" />
                  <span>2887 Peatt Road, Langford, BC V9B 3V7</span>
                </div>
                <a
                  href={mapsHref}
                  target="_blank"
                  rel="noreferrer"
                  class="inline-flex items-center gap-2 font-medium text-navy-700 transition hover:text-brand-700">
                  <Icon class="h-5 w-5 text-brand-700" name="uil:external-link-alt" />
                  Directions
                </a>
              </div>
            </div>

            <div>
              <h2 class="inline-flex rounded-full bg-brand-50 px-3 py-1.5 text-xs font-bold tracking-[0.08em] text-brand-700 uppercase">Contact Us</h2>
              <div class="mt-5 space-y-3 text-lg text-body">
                <div class="flex items-center gap-3">
                  <Icon class="h-5 w-5 shrink-0 text-brand-700" name="uil:phone" />
                  <a href="tel:+17784300387" class="transition hover:text-brand-700">778-430-0387</a>
                </div>
                <div class="flex items-center gap-3">
                  <Icon class="h-5 w-5 shrink-0 text-brand-700" name="uil:envelope" />
                  <a href="mailto:info@scviimmigrationlaw.ca" class="break-all transition hover:text-brand-700">info@scviimmigrationlaw.ca</a>
                </div>
                <div class="flex items-center gap-3">
                  <Icon class="h-5 w-5 shrink-0 text-brand-700" name="uil:clock" />
                  <span>Monday to Thursday, 9:00 am to 4:00 pm</span>
                </div>
              </div>
            </div>
          </div>
          <div class="rounded-[18px] bg-white p-6 shadow-[0_4px_16px_rgba(15,36,64,0.06)] sm:p-8">
            <Contactform />
          </div>
        </div>
      </Container>
    </section>
  </main>
</Layout>
